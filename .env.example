# ─── AXIOM Environment Configuration ───────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to version control.

# Application
APP_ENV=development
APP_NAME=AXIOM
APP_VERSION=0.1.0
DEBUG=true

# Security
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MINIMUM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://axiom:axiom_dev@localhost:5432/axiom_db

# AI Engine
OPENAI_API_KEY=your_key_here
AI_MODEL=gpt-4o
AI_LOCAL_MODE=false
LOCAL_MODEL_PATH=

# Geospatial
DEFAULT_CRS=EPSG:4326

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
